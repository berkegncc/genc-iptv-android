<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive icon (API 26+). Legacy `.webp` files in mipmap-*dpi handle older APIs.

    `<monochrome>` provides the silhouette used by Android 13+ themed icons
    and notification small-icons.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background" />
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
    <monochrome android:drawable="@drawable/ic_logo_g_mark_mono" />
</adaptive-icon>
