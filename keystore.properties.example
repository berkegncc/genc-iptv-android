# Copy to keystore.properties (gitignored) and fill in to sign release builds.
# Alternatively set RELEASE_STORE_FILE / RELEASE_STORE_PASSWORD /
# RELEASE_KEY_ALIAS / RELEASE_KEY_PASSWORD env vars (these take precedence).
# storeFile is resolved relative to the repo root.
storeFile=genciptv-release.jks
storePassword=CHANGE_ME
keyAlias=genciptv
keyPassword=CHANGE_ME
